{
  "name": "node-firecracker",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-24-bookworm",
  "runArgs": ["--device=/dev/kvm"],
  "postCreateCommand": "sudo chmod 666 /dev/kvm 2>/dev/null || true; npm install",
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "vitest.explorer"]
    }
  }
}
